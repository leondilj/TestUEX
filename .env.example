# Lido pelo Docker Compose para substituir ${ANTHROPIC_API_KEY} em docker-compose.yml
# (convenção nativa do Compose para um .env na raiz do projeto — não confundir com api/.env,
# que é lido pelo pydantic-settings quando a API roda fora do Docker). Nunca commitar — já
# está no .gitignore.
ANTHROPIC_API_KEY=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
ASSISTANT_MODEL=claude-haiku-4-5-20251001

# Observabilidade do assistente (ADR-005) — Langfuse self-host local, opcional.
# Suba antes com: docker compose -f docker-compose.langfuse.yml --env-file .env.langfuse up -d
# Use os MESMOS valores de LANGFUSE_INIT_PROJECT_PUBLIC_KEY/SECRET_KEY do .env.langfuse.
# Vazio desabilita o tracing (assistente funciona normalmente, sem enviar dados).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://host.docker.internal:3001
