# Lido pelo docker-compose.langfuse.yml (self-host local do Langfuse — ADR-005):
#   docker compose -f docker-compose.langfuse.yml --env-file .env.langfuse up -d
# Copiar para `.env.langfuse` e preencher os CHANGEME antes de subir. Nunca commitar
# o arquivo real (`.env.langfuse` já está no .gitignore, igual ao `.env` da raiz).

# --- Segredos internos do Langfuse (qualquer valor aleatório forte serve) ---
# Gerar com: openssl rand -hex 32
SALT=CHANGEME_openssl_rand_hex_32
ENCRYPTION_KEY=CHANGEME_openssl_rand_hex_32
NEXTAUTH_SECRET=CHANGEME_openssl_rand_hex_32

# --- Credenciais da infra interna (Postgres/ClickHouse/Redis/MinIO do Langfuse) ---
# Só precisam ser fortes se a máquina expuser essas portas fora do localhost — não é
# o caso aqui (só langfuse-web:3001 e minio:9090 saem do 127.0.0.1), mas evite reusar
# senhas de produção.
#
# IMPORTANTE: o docker-compose.langfuse.yml usa DATABASE_URL/LANGFUSE_S3_*_SECRET_ACCESS_KEY
# com um default hardcoded (herdado do compose oficial do Langfuse) — NÃO derivam
# automaticamente de POSTGRES_PASSWORD/MINIO_ROOT_PASSWORD. Ao trocar as duas senhas
# abaixo, repita o MESMO valor em DATABASE_URL (troque só a senha na URL) e nas 3
# variáveis LANGFUSE_S3_*_SECRET_ACCESS_KEY, senão langfuse-web/worker sobem mas falham
# ao autenticar no Postgres/MinIO internos (erro comum: "Authentication failed against
# database server").
POSTGRES_PASSWORD=CHANGEME
DATABASE_URL=postgresql://postgres:CHANGEME@postgres:5432/postgres
CLICKHOUSE_PASSWORD=CHANGEME
REDIS_AUTH=CHANGEME
MINIO_ROOT_PASSWORD=CHANGEME
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=CHANGEME
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=CHANGEME
LANGFUSE_S3_BATCH_EXPORT_SECRET_ACCESS_KEY=CHANGEME

# --- Provisionamento automático no primeiro start (evita criar conta pela UI) ---
# Depois de gerar essas duas chaves (formato livre, ex: `pk-lf-taskly-local` /
# `sk-lf-taskly-local-<hex aleatório>`), copie os MESMOS valores para
# LANGFUSE_PUBLIC_KEY / LANGFUSE_SECRET_KEY no `.env` da raiz (lido pelo
# docker-compose.yml principal) — é o par de chaves que a API vai usar para
# autenticar no Langfuse.
LANGFUSE_INIT_ORG_ID=taskly-local
LANGFUSE_INIT_ORG_NAME=Taskly (local)
LANGFUSE_INIT_PROJECT_ID=taskly-assistant
LANGFUSE_INIT_PROJECT_NAME=Taskly — assistente
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-taskly-local
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-taskly-local-CHANGEME
LANGFUSE_INIT_USER_EMAIL=dev@taskly.local
LANGFUSE_INIT_USER_NAME=Taskly Dev
LANGFUSE_INIT_USER_PASSWORD=CHANGEME_min_8_chars
